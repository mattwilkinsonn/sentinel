{
  "name": "ts-scripts",
  "private": true,
  "type": "module",
  "scripts": {
    "fmt:move": "prettier --plugin @mysten/prettier-plugin-move --write \"../move-contracts/*/sources/**/*.move\" \"../move-contracts/*/tests/**/*.move\"",
    "fmt:move:check": "prettier --plugin @mysten/prettier-plugin-move --check \"../move-contracts/*/sources/**/*.move\" \"../move-contracts/*/tests/**/*.move\"",
    "lint": "biome lint .",
    "fmt": "biome format --write .",
    "fmt:check": "biome check . && bun run fmt:move:check"
  },
  "dependencies": {
    "@mysten/sui": "^2.0.0",
    "@noble/hashes": "^1.8.0",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@mysten/prettier-plugin-move": "^0.3.5",
    "@types/node": "^24.10.4",
    "prettier": "^3.3.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
