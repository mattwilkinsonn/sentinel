{
  "compilerOptions": {
    "strict": true,
    "rootDir": "src",
    "outDir": "bin",
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "sourceMap": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true
  },
  "include": ["src/**/*.ts"]
}
