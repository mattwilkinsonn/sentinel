package sentinel:threat-engine@0.1.0;

world threat-engine {
    // Consume events from sentinel.events JetStream
    import wasmcloud:messaging/consumer@0.2.0;

    // Read/write threat profiles and caches
    import wasi:keyvalue/store@0.2.0-draft;
    import wasi:keyvalue/atomics@0.2.0-draft;

    // Logging
    import wasi:logging/logging@0.1.0-draft;

    // Message handler export — wasmCloud invokes this for each consumed message
    export wasmcloud:messaging/handler@0.2.0;
}
