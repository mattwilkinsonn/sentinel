# Network
SUI_NETWORK=testnet
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
TENANT=dev

# World contracts package ID (from deployment)
WORLD_PACKAGE_ID=

# Bounty board package (set after `sui move publish`)
BUILDER_PACKAGE_ID=
EXTENSION_CONFIG_ID=
BOUNTY_BOARD_ID=


# Admin key (deployer)
ADMIN_PRIVATE_KEY=

# Player keys
PLAYER_A_PRIVATE_KEY=

# Object IDs (set from game state)
STORAGE_UNIT_ID=
CHARACTER_ID=

# For posting bounties
TARGET_CHARACTER_ITEM_ID=
REWARD_TYPE_ID=
REWARD_QUANTITY=
BOUNTY_DURATION_MS=0

# For claiming bounties
HUNTER_CHARACTER_ID=
KILLMAIL_ID=
BOUNTY_ID=

# For cancelling bounties
POSTER_CHARACTER_ID=

# Backend: Postgres (optional — runs in-memory if unset)
DATABASE_URL=postgresql://sentinel:sentinel@localhost/sentinel

# Backend: Sentinel
SENTINEL_PACKAGE_ID=
THREAT_REGISTRY_ID=
SENTINEL_ADMIN_CAP_ID=
SENTINEL_PUBLISH_INTERVAL_MS=30000
SENTINEL_API_PORT=3001
