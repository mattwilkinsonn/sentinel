# ── Network ────────────────────────────────────────────────────────────────────
# Which Sui network to target (used by ts-scripts)
SUI_NETWORK=testnet
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
# Deployment tenant label (used by ts-scripts for namespacing)
TENANT=dev

# ── World contracts ─────────────────────────────────────────────────────────────
# EVE Frontier world package — set after `sui move publish` on the world contracts
WORLD_PACKAGE_ID=

# Bounty board package — set after `sui move publish` on the bounty board contracts
BUILDER_PACKAGE_ID=
# Shared object created on first deploy of the builder package
EXTENSION_CONFIG_ID=
BOUNTY_BOARD_ID=

# ── Sui keys ────────────────────────────────────────────────────────────────────
# Ed25519 private key (bech32 suiprivkey1... format) for the backend publisher wallet.
# This wallet pays gas for on-chain threat score publishes.
# In prod this comes from AWS SSM — never commit a real key here.
SUI_PUBLISHER_KEY=

# Ed25519 private key for a player account (used by ts-scripts only, not the backend)
PLAYER_A_PRIVATE_KEY=

# ── ts-script object IDs ────────────────────────────────────────────────────────
# Shared object IDs used by ts-scripts for ad-hoc transactions
STORAGE_UNIT_ID=
CHARACTER_ID=

# For posting bounties
TARGET_CHARACTER_ITEM_ID=
REWARD_TYPE_ID=
REWARD_QUANTITY=
BOUNTY_DURATION_MS=0

# For claiming bounties
HUNTER_CHARACTER_ID=
KILLMAIL_ID=
BOUNTY_ID=

# For cancelling bounties
POSTER_CHARACTER_ID=

# ── Backend: database ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://sentinel:sentinel@localhost/sentinel

# ── Backend: Sentinel ───────────────────────────────────────────────────────────
# On-chain object IDs for the Sentinel package (set after deploying sentinel contracts)
SENTINEL_PACKAGE_ID=
# Shared ThreatRegistry object
THREAT_REGISTRY_ID=
# AdminCap object owned by SUI_PUBLISHER_KEY — needed for on-chain score writes
SENTINEL_ADMIN_CAP_ID=

# How often (ms) the backend checks if any threat scores need publishing on-chain
SENTINEL_PUBLISH_INTERVAL_MS=30000
# Minimum score change in basis points (1bp = 0.01 score) to trigger an on-chain publish.
# 100bp = a score change of 1.00. Raise this to reduce gas spend.
SENTINEL_PUBLISH_THRESHOLD_BP=100

SENTINEL_API_PORT=3001

# Log level for sentinel_backend crate
SENTINEL_LOG_LEVEL=info
# Log level for all other crates (tonic, hyper, tower, etc.)
CRATES_LOG_LEVEL=warn
# "pretty" for human-readable dev logs, "json" for structured production output
LOG_FORMAT=pretty

# ── Backend: external endpoints ─────────────────────────────────────────────────
# Sui fullnode gRPC — used for live event streaming
SUI_GRPC_URL=https://fullnode.testnet.sui.io:443
# Sui GraphQL — used for historical object/event queries
SUI_GRAPHQL_URL=https://graphql.testnet.sui.io/graphql
# EVE Frontier world REST API (Stillness) — used for character/location lookups
WORLD_API_URL=https://world-api-stillness.live.tech.evefrontier.com

# ── Discord bot ─────────────────────────────────────────────────────────────────
# Optional. Only used when building with --features discord.
# Use the Sentinel-Dev bot token for local dev; prod token lives in AWS SSM.
# Alert channel is configured per-guild at runtime via /alerts set #channel.
DISCORD_TOKEN=
